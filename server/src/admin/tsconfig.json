{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "allowJs": false,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": [
    "./",
    "../plugins/**/admin/src/**/*"
  ],

  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ]
}